# SmartFinanceEngine Configuration
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════════
#  FLASK SERVER
# ═══════════════════════════════════════════════════════════
# Secret key for session management (generate a new one for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development
FLASK_DEBUG=False

# ═══════════════════════════════════════════════════════════
#  DATABASE
# ═══════════════════════════════════════════════════════════
# Default PIN for new users (must be 4 digits)
# Users should change this on their first login
DEFAULT_USER_PIN=1234

# ═══════════════════════════════════════════════════════════
#  GROQ API (for AI-powered document analysis & chat)
# ═══════════════════════════════════════════════════════════
# Get your free API key from: https://console.groq.com/keys
# Leave empty to disable AI features (app will fall back to Tesseract OCR)
GROQ_API_KEY=

# ═══════════════════════════════════════════════════════════
#  EMAIL SERVICE (for budget alerts)
# ═══════════════════════════════════════════════════════════
# Users configure this in the app UI via Settings
# These are optional defaults (users can override)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TIMEOUT=15

# ═══════════════════════════════════════════════════════════
#  APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════
# Server port
PORT=5000

# Host to bind to (use 0.0.0.0 to allow external connections)
HOST=localhost

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
